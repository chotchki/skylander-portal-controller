source "https://rubygems.org"

# GitHub Pages compatible Jekyll stack. Pin to the github-pages gem so local
# previews use the same Jekyll + plugin versions GitHub Pages ships.
gem "github-pages", group: :jekyll_plugins

# Minima is the default GitHub Pages theme. Pulled in transitively by
# github-pages, but listed explicitly for clarity.
gem "minima", "~> 2.5"

group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-seo-tag"
end

# Windows + JRuby: tzinfo shim. Harmless on other platforms.
platforms :mingw, :x64_mingw, :mswin, :jruby do
  gem "tzinfo", ">= 1", "< 3"
  gem "tzinfo-data"
end

# Webrick is no longer in stdlib on Ruby 3.x; Jekyll serve needs it.
gem "webrick", "~> 1.8"
