# Copy to `.env.dev` and fill in.
# Only loaded when the server is built with the `dev-tools` feature (default).

# Absolute path to rpcs3.exe. The server reads the companion config/games.yml.
RPCS3_EXE=C:/emuluators/rpcs3/rpcs3.exe

# Root of the firmware pack (the folder containing the game subfolders).
FIRMWARE_PACK_ROOT=C:/Users/chris/workspace/Skylanders Characters Pack for RPCS3

# Optional — defaults to <RPCS3_EXE dir>/config/games.yml.
# GAMES_YAML=C:/emuluators/rpcs3/config/games.yml

# Optional — HTTP port. Defaults to 8765.
# BIND_PORT=8765

# Optional — set to `mock` to swap in the mock driver (no RPCS3 needed).
# SKYLANDER_PORTAL_DRIVER=mock
