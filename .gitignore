# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/


# Added by cargo

/target

# Project-specific
/logs/
/dev-data/
# Runtime-only subtree of the shared asset dir — server writes scanned
# `.sky` dumps here when DATA_ROOT defaults to `./data/`. Tracked
# sibling dirs (figures.json, images/, games/, LICENSE.md) stay in.
/data/scanned/
.env.dev
.env
node_modules/
Thumbs.db
.DS_Store
.claude/settings.local.json
.claude/settings.json
# Per-agent scratch worktrees the Claude Code harness creates when
# isolation: "worktree" is requested — each is its own git checkout
# and shouldn't end up in the main repo.
.claude/worktrees/

# Standalone tool crates and trunk output
/tools/*/target/
/tools/*/dist/
/phone/target/
/phone/dist/
# Cached download of the standalone tailwindcss CLI (PLAN 9.1).
# tools/tailwind-build downloads the binary on first run, ~50MB,
# version-suffixed so a `TAILWIND_VERSION` bump invalidates cleanly.
/phone/.tailwind-cache/
# Generated Tailwind utility bundle. Source of truth is
# `phone/styles/input.css`; the tailwindcss CLI emits this on every
# trunk build via the pre_build hook.
/phone/styles/tailwind.css

# Scraped hero images are not committed by default — they'd blow past the
# repo size budget at ~150-200KB × 500 figures. Only thumbs are versioned.
# Re-generate locally with `cargo run -p skylander-wiki-scrape` if you need
# the higher-resolution assets.
/data/images/**/hero.png
